# =============================================================================
# DeltaGlider Proxy — secrets (EXAMPLE)
# =============================================================================
# Copy to `secrets.env` and fill from your secret manager. NEVER commit the
# filled copy (the .gitignore here blocks `secrets.env`).
#
# This is a docker-compose env_file: KEY=value, values taken LITERALLY (no shell
# quoting/expansion). The proxy reads it via `env_file:` and expands the
# matching ${env:NAME} placeholders in deltaglider_proxy.yaml.
# =============================================================================

# ── Native DGP_* env (read directly by the proxy) ───────────────────────────

# Admin GUI / config-DB master secret. Provide the BCRYPT HASH, not plaintext
# (generate with: `deltaglider_proxy --set-bootstrap-password`, or htpasswd -nbBC 12).
DGP_BOOTSTRAP_PASSWORD_HASH=

# ── ${env:...} placeholders referenced by deltaglider_proxy.yaml ─────────────

# Upstream S3 backend.
S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
S3_REGION=eu-central-1
S3_PATH_STYLE=false                 # true for MinIO / most non-AWS S3 stores
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Bootstrap SigV4 pair clients use to sign requests against the proxy.
PROXY_ACCESS_KEY_ID=
PROXY_SECRET_ACCESS_KEY=

# Per-user secret(s) — only if you enable declarative IAM in the YAML.
# USER_CI_UPLOADER_SECRET=

# Optional: pin a specific image instead of :latest.
# DGP_IMAGE_TAG=1.3.0
