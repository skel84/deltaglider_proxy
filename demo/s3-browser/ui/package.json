{
  "name": "deltaglider-s3-browser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:strict": "eslint 'src/**/*.{ts,tsx}' --max-warnings 0",
    "test:permissions": "node scripts/permissions-regression-test.mjs",
    "test:writable-prefixes": "node scripts/writable-prefixes-regression-test.mjs",
    "test:virtual-prefix-scan": "node scripts/virtual-prefix-scan-regression-test.mjs",
    "test:storage-path": "node scripts/storage-path-regression-test.mjs",
    "test:upload-telemetry": "node scripts/upload-telemetry-regression-test.mjs",
    "test:page-size": "node scripts/page-size-regression-test.mjs",
    "e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "knip": "knip"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.1044.0",
    "@aws-sdk/s3-request-presigner": "^3.988.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.100.1",
    "antd": "^6.3.0",
    "mermaid": "^11.14.0",
    "minisearch": "^7.2.0",
    "motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.73.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.56.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "knip": "^5.88.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0"
  }
}
