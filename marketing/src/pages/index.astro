---
// Homepage — rewritten 2026-06. Structure: one problem-first hero, then
// each section answers exactly one question, in the order a skeptical
// engineer asks them:
//   hero         what is it, why do I care
//   Scale        the claim drawn to scale + the ZIP objection (same artifact)
//   DropIn       what adoption costs (one config line) + trust facts
//   ControlPlane the other half of the product + real admin-UI screens
//   DueDiligence the visitor's own questions, answered with links
//   Fit          is it for MY workload (honest no's) + where to go next
//   Quickstart   let me touch it
// No section repeats another's job. Casualties of the rethink: the stats
// band, the abstract flow diagram, the standalone gallery, the doors grid,
// and the alternatives comparison table — each either re-told a neighbour's
// story or duplicated the nav.

import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import TestimonialsBlock from '../components/TestimonialsBlock.astro';
import WorkloadFitTable from '../components/WorkloadFitTable.astro';
import HeroSlideshow from '../components/HeroSlideshow.tsx';
import StorageScale from '../components/StorageScale.astro';
import DropIn from '../components/DropIn.astro';
import ControlPlane from '../components/ControlPlane.astro';
import {
  organizationSchema,
  webSiteSchema,
  softwareApplicationSchema,
} from '../lib/seo';
---

<BaseLayout
  title="DeltaGlider Proxy — store a hundred versions, pay for one"
  description="A drop-in S3 proxy that stores each new version of a binary artifact as a tiny delta. Same S3 API, zero client changes — plus IAM, SSO, replication, lifecycle, and encryption at rest on any S3-compatible backend. Open source, GPL-3.0."
>
  <Fragment slot="json-ld">
    <JsonLd schema={organizationSchema()} />
    <JsonLd schema={webSiteSchema()} />
    <JsonLd schema={softwareApplicationSchema()} />
  </Fragment>

  {/* ============================== HERO ============================== */}
  <section class="hero">
    <div class="shell hero-grid hero-grid--bleed">
      <div class="hero-copy">
        <span class="hero-eyebrow">
          <span class="hero-eyebrow-dot"></span>
          Open source · GPL-3.0 · one binary
        </span>

        <h1>Store a hundred versions. Pay&nbsp;for&nbsp;one.</h1>

        <p class="hero-lede">
          Every build, dump, and firmware image you ship is mostly the one
          before it — and your bucket bills you full price for every copy.
          DeltaGlider Proxy is a <strong>drop-in S3 proxy</strong> that
          stores each new version as a tiny delta against the last full
          copy. Same S3 API, same buckets, <strong>zero client
          changes</strong>.
        </p>

        <p class="hero-lede hero-lede-secondary">
          And since every byte already flows through it, it's also your
          storage control plane: per-user IAM and SSO, replication,
          lifecycle, encryption at rest — on any S3-compatible backend,
          including the cheap ones.
        </p>

        <div class="hero-ctas">
          <a href="/trial" class="btn btn-brand">Start free trial&nbsp;&rarr;</a>
          <a href="/docs/tutorials/first-delta-savings" class="btn">See it in 15 minutes</a>
          <a href="https://github.com/beshu-tech/deltaglider_proxy" class="btn btn-ghost">GitHub</a>
        </div>

        <p class="hero-trust">
          Built by <strong>Beshu Tech</strong> — the
          <a href="https://readonlyrest.com">ReadonlyREST</a> team, since
          2017. Our own 1.71&nbsp;TB build catalog is migrating through it
          <a href="/case-studies/readonlyrest-builds">in public, bugs and all</a>.
        </p>
      </div>

      <div class="hero-visual hero-visual--bleed">
        <HeroSlideshow client:visible />
      </div>
    </div>
  </section>

  {/* ===================== THE CLAIM, DRAWN TO SCALE ================== */}
  <StorageScale />

  {/* ============================ DROP-IN ============================= */}
  <DropIn />

  {/* ======================= THE OTHER HALF =========================== */}
  <ControlPlane />

  {/* ====================== DUE DILIGENCE ============================= */}
  <section class="section section-alt">
    <div class="shell">
      <span class="section-eyebrow">Due diligence</span>
      <h2>The questions you'd ask anyway</h2>

      <p>
        Answered with links, so you can check instead of believe.
      </p>

      <div class="dd-grid">
        <article class="dd-card" data-n="01">
          <h3 class="dd-q">Will it corrupt my artifacts?</h3>
          <p class="dd-a">
            Every delta read is rebuilt and SHA-256-checked against the
            hash recorded at upload — and 1,100+ unit tests plus an
            integration matrix against real MinIO gate every merge.
          </p>
          <a class="dd-link" href="https://github.com/beshu-tech/deltaglider_proxy">Read the source — it's GPL-3.0 →</a>
        </article>

        <article class="dd-card dd-card--accent" data-n="02">
          <h3 class="dd-q">What breaks in production?</h3>
          <p class="dd-a">
            Here's what broke in ours: we pushed our own 1.71&nbsp;TB
            release catalog through it and published every bug we hit —
            upstream TMPDIR, proxy timeouts, EBS exhaustion — with the
            fixes.
          </p>
          <a class="dd-link" href="/case-studies/readonlyrest-builds">Read the migration log →</a>
        </article>

        <article class="dd-card dd-card--accent" data-n="03">
          <h3 class="dd-q">Will bugs get fixed — or hidden?</h3>
          <p class="dd-a">
            A five-investigator correctness audit surfaced 10 bugs; all
            fixed, each pinned by a regression test, written up
            bug-by-bug where you can read them.
          </p>
          <a class="dd-link" href="https://github.com/beshu-tech/deltaglider_proxy/blob/main/CHANGELOG.md">The bug-by-bug CHANGELOG →</a>
        </article>

        <article class="dd-card" data-n="04">
          <h3 class="dd-q">Who answers when it breaks at 2 a.m.?</h3>
          <p class="dd-a">
            The people whose names are in <code>git log</code>. No
            outsourced first line, no chatbot — your mail lands with the
            engineers who wrote the code.
          </p>
          <a class="dd-link" href="mailto:contact@beshu.tech?subject=DeltaGlider%20-%20General%20inquiry">contact@beshu.tech →</a>
        </article>
      </div>

      <TestimonialsBlock />
    </div>
  </section>

  {/* ============================ HONEST FIT ========================== */}
  <section class="section">
    <div class="shell">
      <span class="section-eyebrow">Honest positioning</span>
      <WorkloadFitTable />

      <p class="fit-next">
        Then put your real numbers into the
        <a href="/pricing">savings calculator</a> — it answers in 30
        seconds. There's also a longer pitch
        <a href="/saas">for platform teams</a> and one
        <a href="/regulated">for regulated buyers</a>.
      </p>
    </div>
  </section>

  {/* ============================ QUICKSTART ========================== */}
  <section class="section section-alt">
    <div class="shell">
      <span class="section-eyebrow">Get started</span>
      <h2>Touch it in 60 seconds</h2>

      <pre><code>docker run --rm -it -p 9000:9000 -v dgp-data:/data \
  -e DGP_AUTHENTICATION=none \
  beshultd/deltaglider_proxy</code></pre>

      <p>
        Open <code>http://localhost:9000/_/</code> for the browser, or
        point any S3 SDK at <code>http://localhost:9000</code>. Open
        access is for a localhost first look —
        <a href="/docs/tutorials/secure-your-proxy">the second tutorial
        locks it down</a>.
      </p>

      <p style="margin-top: 1.5rem;">
        <a href="/docs/tutorials/first-delta-savings" class="btn btn-brand">Full tutorial</a>
        <a href="/trial" class="btn" style="margin-left: 0.4rem;">30-day support trial</a>
        <a href="https://github.com/beshu-tech/deltaglider_proxy" class="btn" style="margin-left: 0.4rem;">GitHub</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-lede-secondary {
    font-size: 0.98rem;
    margin-top: 0.75rem;
  }

  .dd-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin: 2.5rem 0 3.5rem;
  }

  @media (min-width: 760px) {
    .dd-grid { grid-template-columns: 1fr 1fr; }
  }

  .dd-card {
    position: relative;
    overflow: hidden;
    padding: 2.2rem 2.4rem 2.1rem;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 16px;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .dd-card:hover {
    transform: translateY(-3px);
    border-color: rgba(34, 211, 238, 0.45);
    box-shadow: var(--shadow-md);
  }

  .dd-card--accent:hover {
    border-color: rgba(217, 70, 239, 0.5);
  }

  /* giant watermark number — graphic weight without clutter */
  .dd-card::before {
    content: attr(data-n);
    position: absolute;
    top: -1.6rem;
    right: -0.6rem;
    font-family: var(--font-mono);
    font-size: 7.5rem;
    font-weight: 800;
    line-height: 1;
    color: rgba(34, 211, 238, 0.08);
    pointer-events: none;
  }
  .dd-card--accent::before {
    color: rgba(217, 70, 239, 0.09);
  }

  .dd-q {
    margin: 0 0 0.8rem;
    font-size: 1.45rem;
    font-weight: 800;
    letter-spacing: -0.015em;
    line-height: 1.15;
    color: var(--ink-strong);
    max-width: 18ch;
  }

  .dd-a {
    margin: 0 0 1.1rem;
    color: var(--ink-soft);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 48ch;
  }

  .dd-link {
    font-weight: 600;
    color: var(--brand-dark);
    text-decoration: none;
  }
  .dd-link:hover { text-decoration: underline; }

  .fit-next {
    margin-top: 1.5rem;
    color: var(--ink-soft);
  }
</style>
