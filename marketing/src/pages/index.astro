---
// Homepage — rewritten 2026-06. Structure: one problem-first hero, then
// each section answers exactly one question, in the order a skeptical
// engineer asks them:
//   hero        what is it, why do I care
//   Scale       the claim drawn to scale (ten versions, two buckets)
//   DropIn      what adoption costs (one config line) + trust facts
//   Mechanism   "but ZIPs won't diff" — the obvious objection
//   Capabilities what else do I get
//   Proof       who runs it in anger
//   Fit         is it for MY workload (honest no's included)
//   Engineering can I trust the code and the people
//   Doors       where do I go next
//   Quickstart  let me touch it
// No section repeats another's job — the old page had three overlapping
// "what it does" blocks; they're consolidated into Capabilities.

import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import TestimonialsBlock from '../components/TestimonialsBlock.astro';
import SimoneCallout from '../components/SimoneCallout.astro';
import MechanismExplanation from '../components/MechanismExplanation.astro';
import WorkloadFitTable from '../components/WorkloadFitTable.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import ScreenshotGallery from '../components/ScreenshotGallery.astro';
import HeroSlideshow from '../components/HeroSlideshow.tsx';
import StorageScale from '../components/StorageScale.astro';
import DropIn from '../components/DropIn.astro';
import Capabilities from '../components/Capabilities.astro';
import {
  organizationSchema,
  webSiteSchema,
  softwareApplicationSchema,
} from '../lib/seo';
---

<BaseLayout
  title="DeltaGlider Proxy — store a hundred versions, pay for one"
  description="A drop-in S3 proxy that stores each new version of a binary artifact as a tiny delta. Same S3 API, zero client changes — plus IAM, SSO, replication, lifecycle, and encryption at rest on any S3-compatible backend. Open source, GPL-3.0."
>
  <Fragment slot="json-ld">
    <JsonLd schema={organizationSchema()} />
    <JsonLd schema={webSiteSchema()} />
    <JsonLd schema={softwareApplicationSchema()} />
  </Fragment>

  {/* ============================== HERO ============================== */}
  <section class="hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <span class="hero-eyebrow">
          <span class="hero-eyebrow-dot"></span>
          Open source · GPL-3.0 · one binary
        </span>

        <h1>Store a hundred versions. Pay&nbsp;for&nbsp;one.</h1>

        <p class="hero-lede">
          Every build, dump, and firmware image you ship is mostly the one
          before it — and your bucket bills you full price for every copy.
          DeltaGlider Proxy is a <strong>drop-in S3 proxy</strong> that
          stores each new version as a tiny delta against the last full
          copy. Same S3 API, same buckets, <strong>zero client
          changes</strong>.
        </p>

        <p class="hero-lede hero-lede-secondary">
          And since every byte already flows through it, it's also your
          storage control plane: per-user IAM and SSO, replication,
          lifecycle, encryption at rest — on any S3-compatible backend,
          including the cheap ones.
        </p>

        <div class="hero-ctas">
          <a href="/trial" class="btn btn-brand">Start free trial&nbsp;&rarr;</a>
          <a href="/docs/tutorials/first-delta-savings" class="btn">See it in 15 minutes</a>
          <a href="https://github.com/beshu-tech/deltaglider_proxy" class="btn btn-ghost">GitHub</a>
        </div>

        <p class="hero-trust">
          Built by <strong>Beshu Tech</strong> — the
          <a href="https://readonlyrest.com">ReadonlyREST</a> team, since
          2017. Our own 1.71&nbsp;TB build catalog is migrating through it
          <a href="/case-studies/readonlyrest-builds">in public, bugs and all</a>.
        </p>
      </div>

      <div class="hero-visual">
        <HeroSlideshow client:visible />
      </div>
    </div>
  </section>

  {/* ===================== THE CLAIM, DRAWN TO SCALE ================== */}
  <StorageScale />

  {/* ============================ DROP-IN ============================= */}
  <DropIn />

  {/* ===================== THE OBVIOUS OBJECTION ====================== */}
  <section class="section">
    <div class="shell">
      <MechanismExplanation />
    </div>
  </section>

  {/* ============================ CAPABILITIES ======================== */}
  <Capabilities />

  {/* ====================== THE WHOLE CONTROL PLANE =================== */}
  <section class="section section-alt">
    <div class="shell">
      <span class="section-eyebrow">In the box</span>
      <h2>One admin surface for all of it</h2>
      <p>
        Buckets, backends, users, jobs, events, audit, trace — managed
        from the embedded UI or as plain YAML, your pick. Every screen
        below ships inside the binary.
      </p>
      <ScreenshotGallery />
    </div>
  </section>

  {/* ========================= RUN IN ANGER =========================== */}
  <section class="section">
    <div class="shell">
      <span class="section-eyebrow">Run in anger</span>
      <h2>We migrated our own history through it — in public</h2>

      <p>
        145 plugin versions, 8 years of release history, 1.71&nbsp;TB. The
        migration log names the bugs we hit and what they cost to fix —
        because a storage product that hides its own incidents is asking
        you to find them for it.
      </p>

      <SimoneCallout />
      <TestimonialsBlock />
    </div>
  </section>

  {/* ============================ HONEST FIT ========================== */}
  <section class="section section-alt">
    <div class="shell">
      <span class="section-eyebrow">Honest positioning</span>
      <h2>Where it wins — and where it won't</h2>

      <p>
        Delta compression pays off when versions resemble each other.
        If your workload doesn't look like that, the proxy still gives
        you the control plane — but the savings claim doesn't apply,
        and we'd rather you know now:
      </p>

      <WorkloadFitTable />
      <ComparisonTable />
    </div>
  </section>

  {/* ============================ ENGINEERING ========================= */}
  <section class="section">
    <div class="shell">
      <span class="section-eyebrow">Engineering</span>
      <h2>Built like we mean it</h2>

      <ul class="proof-list">
        <li>
          <strong>1,100+ unit tests</strong>, clippy
          <code>-D warnings</code> clean, and a curated integration
          matrix against real MinIO — on every merge.
        </li>
        <li>
          <strong>We hunt our own bugs and publish them.</strong> A
          five-investigator correctness audit (concurrency, auth,
          storage, wire, errors) surfaced 10 bugs; all fixed, each
          pinned by a regression test, written up bug-by-bug in the
          <a href="https://github.com/beshu-tech/deltaglider_proxy/blob/main/CHANGELOG.md">CHANGELOG</a>.
        </li>
        <li>
          <strong>The people who wrote it answer your tickets.</strong>
          No outsourced first line, no chatbot. Email
          <a href="mailto:contact@beshu.tech?subject=DeltaGlider%20-%20General%20inquiry">contact@beshu.tech</a>
          and the reply comes from someone whose name is in
          <code>git log</code>.
        </li>
      </ul>
    </div>
  </section>

  {/* ============================ NEXT DOORS ========================== */}
  <section class="section section-alt">
    <div class="shell">
      <h2>Where to read next</h2>
      <div class="door-grid">
        <a class="door" href="/saas">
          <h3>For SaaS / platform teams →</h3>
          <p>Versioned-artifact storage costs eating your AWS bill.</p>
        </a>
        <a class="door" href="/regulated">
          <h3>For regulated buyers →</h3>
          <p>Encryption-at-rest with local key custody on cheap S3-compatible backends.</p>
        </a>
        <a class="door" href="/pricing">
          <h3>Pricing + savings calculator →</h3>
          <p>Type your numbers. Get an honest answer in 30 seconds.</p>
        </a>
        <a class="door" href="/trial">
          <h3>30-day production support trial →</h3>
          <p>Try the relationship. The software's free regardless.</p>
        </a>
      </div>
    </div>
  </section>

  {/* ============================ QUICKSTART ========================== */}
  <section class="section">
    <div class="shell">
      <span class="section-eyebrow">Get started</span>
      <h2>Touch it in 60 seconds</h2>

      <pre><code>docker run --rm -it -p 9000:9000 -v dgp-data:/data \
  -e DGP_AUTHENTICATION=none \
  beshultd/deltaglider_proxy</code></pre>

      <p>
        Open <code>http://localhost:9000/_/</code> for the browser, or
        point any S3 SDK at <code>http://localhost:9000</code>. Open
        access is for a localhost first look —
        <a href="/docs/tutorials/secure-your-proxy">the second tutorial
        locks it down</a>.
      </p>

      <p style="margin-top: 1.5rem;">
        <a href="/docs/tutorials/first-delta-savings" class="btn">Full tutorial</a>
        <a href="https://github.com/beshu-tech/deltaglider_proxy" class="btn" style="margin-left: 0.4rem;">GitHub</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-lede-secondary {
    font-size: 0.98rem;
    margin-top: 0.75rem;
  }

  .proof-list {
    list-style: none;
    padding-left: 0;
    max-width: var(--measure-wide);
    display: grid;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .proof-list li {
    padding: 1rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 6px;
    box-shadow: var(--shadow-sm);
    color: var(--ink-strong);
    line-height: 1.55;
    margin: 0;
  }

  .door-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 2rem 0;
    max-width: var(--measure-wide);
  }

  @media (min-width: 720px) {
    .door-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .door {
    padding: 1.5rem 1.75rem;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 8px;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.1s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .door:hover {
    border-color: var(--brand);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .door h3 {
    margin: 0 0 0.4rem 0;
    color: var(--ink);
    font-size: 1.1rem;
  }

  .door:hover h3 {
    color: var(--brand-dark);
  }

  .door p {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.95rem;
  }
</style>
