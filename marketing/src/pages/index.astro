---
// Homepage — v5 plan §4.1. Visual design pass: alternating sections,
// proper hero, real CTAs, no wall-of-text.

import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import TestimonialsBlock from '../components/TestimonialsBlock.astro';
import CustomerSegmentBlock from '../components/CustomerSegmentBlock.astro';
import SimoneCallout from '../components/SimoneCallout.astro';
import MechanismExplanation from '../components/MechanismExplanation.astro';
import WorkloadFitTable from '../components/WorkloadFitTable.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import ScreenshotGallery from '../components/ScreenshotGallery.astro';
import HeroSlideshow from '../components/HeroSlideshow.tsx';
import {
  organizationSchema,
  webSiteSchema,
  softwareApplicationSchema,
} from '../lib/seo';
---

<BaseLayout
  title="DeltaGlider — S3-compatible storage compression"
  description="Storage compression for S3, behind the same S3 API your apps already use. Open source, GPL-3.0. Built by Beshu Tech, 10 senior engineers since 2017."
>
  <Fragment slot="json-ld">
    <JsonLd schema={organizationSchema()} />
    <JsonLd schema={webSiteSchema()} />
    <JsonLd schema={softwareApplicationSchema()} />
  </Fragment>

  {/* ============================== HERO ============================== */}
  <section class="hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <span class="hero-eyebrow">
          <span class="hero-eyebrow-dot"></span>
          Open source · GPL-3.0
        </span>

        <h1>Cut S3 storage&nbsp;10&times;.<br />Change&nbsp;nothing.</h1>

        <p class="hero-lede">
          A drop-in S3 proxy that stores versioned binaries — artifacts,
          builds, backups, models — as deltas. Same API. Same buckets.
          <strong>Up to 10&times;–100&times; fewer bytes stored.</strong>
        </p>

        <div class="hero-ctas">
          <a href="/pricing" class="btn btn-brand">See what you'd save&nbsp;&rarr;</a>
          <a href="/trial" class="btn">Start free trial</a>
          <a href="https://github.com/beshu-tech/deltaglider_proxy" class="btn btn-ghost">GitHub</a>
        </div>

        <p class="hero-trust">
          <strong>In production</strong> at banks, nuclear research &amp; EU
          institutions, and 2&times; of the S&amp;P&nbsp;500 top&nbsp;5 —
          built by the <a href="https://readonlyrest.com">ReadonlyREST</a>
          team since 2017.
        </p>
      </div>

      <div class="hero-visual">
        <HeroSlideshow client:visible />
      </div>
    </div>
  </section>

  {/* ============================ TESTIMONIALS ========================= */}
  <section class="section section-alt">
    <div class="shell">
      <TestimonialsBlock />
    </div>
  </section>

  {/* ============================ DOGFOODING =========================== */}
  <section class="section">
    <div class="shell">
      <SimoneCallout />
    </div>
  </section>

  {/* ============================ TRUST COPY =========================== */}
  <section class="section section-alt">
    <div class="shell">
      <CustomerSegmentBlock />
    </div>
  </section>

  {/* ============================ WHY ZIP DELTA ======================== */}
  <section class="section">
    <div class="shell">
      <MechanismExplanation />
    </div>
  </section>

  {/* ============================ WORKLOAD FIT ========================= */}
  <section class="section section-alt">
    <div class="shell">
      <WorkloadFitTable />
    </div>
  </section>

  {/* ============================ IN PROGRESS ========================== */}
  <section class="section">
    <div class="shell">
      <span class="section-eyebrow">In progress</span>
      <h2>Migrating ReadonlyREST's build catalog → Hetzner</h2>

      <p>
        Sample so far: a 1.69.0 plugin version compressed
        <strong>88.5×</strong> (2,866 MB → 32.4 MB), bit-perfect
        SHA-256 round-trip through the proxy. About <strong>$9 in EC2
        compute</strong> plus ~$2 in Glacier Bulk-tier retrieval for
        the migration so far.
      </p>

      <p>
        The full migration covers 145 versions, 8 years of release
        history. Final results published as a reproducible case study
        when complete.
      </p>

      <p>
        <a href="/case-studies/readonlyrest-builds" class="btn">
          Read the migration log →
        </a>
      </p>
    </div>
  </section>

  {/* ============================ HOW IT FITS ========================== */}
  <section class="section section-alt">
    <div class="shell">
      <span class="section-eyebrow">Architecture</span>
      <h2>How it fits in your stack</h2>

      <p>
        DeltaGlider is an S3-compatible proxy. Your apps speak SigV4 to
        it. It speaks SigV4 to your bucket. On PUT, it stores either an
        xdelta3 delta against the deltaspace reference or a passthrough
        copy, whichever is smaller. On GET, it reconstructs byte-for-
        byte and streams. The client sees ordinary S3.
      </p>
    </div>
  </section>

  {/* ============================ OPERATOR SURFACE ===================== */}
  <section class="section">
    <div class="shell">
      <span class="section-eyebrow">Beyond compression</span>
      <h2>The operator surface</h2>

      <ul class="feature-list">
        <li>
          <strong>Per-user IAM with ABAC permissions</strong> —
          AWS-IAM grammar via <code>iam-rs</code>, OAuth/OIDC group
          mapping, encrypted SQLCipher config DB.
        </li>
        <li>
          <strong>Replication rules</strong> between buckets and
          backends — run-now, pause/resume, history, optional delete-
          replication.
        </li>
        <li>
          <strong>AES-256-GCM at-rest encryption</strong>, per-object
          IV. Encryption key stays in your runtime; the backend sees
          ciphertext.
        </li>
        <li>
          <strong>Lifecycle, quotas, audit, metrics</strong> —
          lifecycle expiration, event outbox with retries/webhooks,
          soft per-bucket quotas (including <code>quota=0</code> freeze
          for migration windows), Prometheus metrics, in-memory audit
          ring plus structured stdout for SIEM shipping.
        </li>
        <li>
          <strong>Delta efficiency diagnostic panel</strong> — one-
          click scan flags prefixes where the reference baseline
          produces wasted bytes.
        </li>
        <li>
          <strong>Pre-auth admission chain</strong> —
          <code>deny</code>/<code>reject</code>/<code>allow-anonymous</code>
          rules evaluated BEFORE auth. <code>config trace</code> shows
          exactly which rule fired and why.
        </li>
      </ul>

      <p>
        → <a href="/docs/reference">Reference docs</a>
      </p>

      <ScreenshotGallery />
    </div>
  </section>

  {/* ============================ ACCOUNTABILITY ======================= */}
  <section class="section section-alt">
    <div class="shell">
      <span class="section-eyebrow">Support</span>
      <h2>Accountability</h2>

      <p>
        Beshu Tech's 10 senior engineers wrote DeltaGlider; they're the
        ones who answer your support tickets. No outsourced first-
        line. No AI chatbot. Email
        <a href="mailto:contact@beshu.tech?subject=DeltaGlider%20-%20General%20inquiry">contact@beshu.tech</a>
        and the response comes from someone whose name is in
        <code>git log</code>.
      </p>
    </div>
  </section>

  {/* ============================ CORRECTNESS X-RAY ==================== */}
  <section class="section">
    <div class="shell">
      <span class="section-eyebrow">May 2026</span>
      <h2>Correctness x-ray</h2>

      <p>
        A focused audit by five specialised investigators (concurrency,
        auth, storage, HTTP/wire, error handling) surfaced 10 distinct
        correctness bugs across the proxy. All fixed; each pinned by a
        regression test. <strong>769 unit tests</strong> in
        <code>cargo test --lib</code>, +23 added during the audit.
        Clippy <code>-D warnings</code> clean. Bug-by-bug write-up in
        <a href="https://github.com/beshu-tech/deltaglider_proxy/blob/main/CHANGELOG.md">CHANGELOG.md</a>.
      </p>
    </div>
  </section>

  {/* ============================ COMPARISON =========================== */}
  <section class="section section-alt">
    <div class="shell">
      <span class="section-eyebrow">Honest positioning</span>
      <h2>When to use what</h2>
      <ComparisonTable />
    </div>
  </section>

  {/* ============================ NEXT DOORS =========================== */}
  <section class="section">
    <div class="shell">
      <h2>Where to read next</h2>
      <div class="door-grid">
        <a class="door" href="/saas">
          <h3>For SaaS / platform teams →</h3>
          <p>Versioned-artifact storage costs eating your AWS bill.</p>
        </a>
        <a class="door" href="/regulated">
          <h3>For regulated buyers →</h3>
          <p>Encryption-at-rest with local key custody on cheap S3-compatible backends.</p>
        </a>
        <a class="door" href="/pricing">
          <h3>Pricing + savings calculator →</h3>
          <p>Type your numbers. Get an honest answer in 30 seconds.</p>
        </a>
        <a class="door" href="/trial">
          <h3>30-day production support trial →</h3>
          <p>Try the relationship. The software's free regardless.</p>
        </a>
      </div>
    </div>
  </section>

  {/* ============================ QUICKSTART =========================== */}
  <section class="section section-alt">
    <div class="shell">
      <span class="section-eyebrow">Get started</span>
      <h2>Try it in 30 seconds</h2>

      <pre><code>docker run -p 9000:9000 \
  -e DGP_BACKEND=s3 \
  -e DGP_S3_ENDPOINT=https://your-backend \
  -e AWS_ACCESS_KEY_ID=... \
  -e AWS_SECRET_ACCESS_KEY=... \
  ghcr.io/beshu-tech/deltaglider_proxy:latest</code></pre>

      <p>
        Then point your S3 SDK at <code>http://localhost:9000</code>.
        Same SigV4. Same buckets. Same workflow.
      </p>

      <p style="margin-top: 1.5rem;">
        <a href="/docs/quickstart" class="btn">Full quickstart</a>
        <a href="https://github.com/beshu-tech/deltaglider_proxy" class="btn" style="margin-left: 0.4rem;">GitHub</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .feature-list {
    list-style: none;
    padding-left: 0;
    max-width: var(--measure-wide);
    display: grid;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .feature-list li {
    padding: 1rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 6px;
    box-shadow: var(--shadow-sm);
    color: var(--ink-strong);
    line-height: 1.55;
    margin: 0;
  }

  .feature-list li strong {
    color: var(--ink);
    display: block;
    margin-bottom: 0.15rem;
  }

  .door-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 2rem 0;
    max-width: var(--measure-wide);
  }

  @media (min-width: 720px) {
    .door-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .door {
    padding: 1.5rem 1.75rem;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 8px;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.1s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .door:hover {
    border-color: var(--brand);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .door h3 {
    margin: 0 0 0.4rem 0;
    color: var(--ink);
    font-size: 1.1rem;
  }

  .door:hover h3 {
    color: var(--brand-dark);
  }

  .door p {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.95rem;
  }
</style>
