---
// /saas — v5 plan §4.2.
// Cost-driven migration story for SaaS / platform teams.
// Calculator CTA front-and-center; per-version compression table
// (verified, publishable today); migration playbook.

import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import MechanismExplanation from '../components/MechanismExplanation.astro';
import CompressionResultsTable from '../components/CompressionResultsTable.astro';
import { webPageSchema, breadcrumbListSchema } from '../lib/seo';

const title = 'DeltaGlider for SaaS — cut S3 storage cost on versioned artifacts';
const description =
  'Your CI ships a new build every commit. Most share 99% of their bytes. DeltaGlider stores the 1%. Same S3 API, same SDKs, same workflow. Open source, GPL-3.0.';
---

<BaseLayout title={title} description={description}>
  <Fragment slot="json-ld">
    <JsonLd schema={webPageSchema({ path: '/saas', title, description })} />
    <JsonLd
      schema={breadcrumbListSchema([
        { name: 'DeltaGlider', path: '/' },
        { name: 'For SaaS', path: '/saas' },
      ])}
    />
  </Fragment>
  <section class="saas-hero">
    <div class="shell hero-grid">
      <div class="hero-content fade-up">
        <h1>Stop paying AWS to store the same JAR a thousand times.</h1>

        <p class="hero-lede">
          Your CI pipeline ships a new build every commit. Most of those
          builds share 99% of their bytes with the previous one.
          DeltaGlider stores the 1% and reconstructs the rest. Same S3 API.
          Same SDKs. Same workflow.
        </p>

        <div class="hero-ctas">
          <a href="/pricing#calculator" class="btn btn-primary">See what it'd save you</a>
          <a href="/trial" class="btn">30-day trial</a>
          <a href="/docs/quickstart" class="btn">docker run</a>
        </div>
      </div>
      
      <div class="hero-visual fade-up delay-1">
        <div class="abstract-jars">
          <div class="jar jar-1"><span class="jar-label">91 MB</span></div>
          <div class="jar jar-2"></div>
          <div class="jar jar-3"></div>
          <div class="delta-block">
            <span class="delta-stat">148 KB</span>
            <span class="delta-label">Encrypted Delta</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="shell">
    <section class="in-progress fade-up delay-2">
      <div class="in-progress-grid">
        <div class="narrative-col">
          <span class="section-eyebrow">Dogfooding</span>
          <h2>In progress: ReadonlyREST's build catalog → Hetzner</h2>

          <p>
            Beshu Tech is migrating its own ReadonlyREST build catalog off
            AWS S3 to Hetzner via DeltaGlider.
          </p>
          <p>
            Why is 1.38.0 only 4.1× compression? Because the legacy deltaspace mixes ES
            6, 7, and 8 Kibana plugins — structurally dissimilar artifacts
            in one prefix. The Delta Efficiency Panel correctly classifies
            it as "Fair, near Poor." We'd rather tell you that than gloss
            over it.
          </p>

          <p class="case-study-link">→ <a href="/case-studies/readonlyrest-builds">Read full case study</a></p>
        </div>

        <div class="data-col glass-card">
          <h3 class="card-title">Latest Test Runs</h3>
          <CompressionResultsTable detailed={false} />
        </div>
      </div>
    </section>

    <MechanismExplanation />

    <section class="playbook fade-up delay-3">
      <span class="section-eyebrow">Playbook</span>
      <h2>What a migration looks like</h2>

      <div class="playbook-grid">
        <div class="playbook-step">
          <div class="step-number">01</div>
          <h3>Deploy</h3>
          <p>
            Run DeltaGlider in your VPC. Point it at your existing AWS
            bucket — or a new Hetzner / Backblaze / Cloudflare bucket —
            anything S3-compatible.
          </p>
        </div>
        
        <div class="playbook-step">
          <div class="step-number">02</div>
          <h3>Scan</h3>
          <p>
            Use the Delta Efficiency Panel to scan a sample prefix.
            Verify compression is in the range that justifies migration.
          </p>
        </div>

        <div class="playbook-step">
          <div class="step-number">03</div>
          <h3>Stage</h3>
          <p>
            Stage migration bucket-by-bucket using per-bucket aliases
            and <code>quota=0</code> freeze mode during the window.
          </p>
        </div>

        <div class="playbook-step">
          <div class="step-number">04</div>
          <h3>Cutover</h3>
          <p>
            Cut over your apps' S3 endpoint to DeltaGlider. Your SDKs
            remain completely unchanged.
          </p>
        </div>

        <div class="playbook-step">
          <div class="step-number">05</div>
          <h3>Replicate</h3>
          <p>
            Run replication rules to mirror new writes to a DR region if
            you need one.
          </p>
        </div>
      </div>

      <div class="playbook-footer">
        <p>
          Production support helps you with each of these. See
          <a href="/trial">/trial</a> for the 30-day try-the-relationship
          offer.
        </p>
      </div>
    </section>

    <section class="cta">
      <h2>Next step</h2>
      <div class="hero-ctas">
        <a href="/pricing#calculator" class="btn btn-primary">Try the savings calculator</a>
        <a href="/trial" class="btn">Start a 30-day trial</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* === Animations === */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .fade-up {
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
  
  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }

  /* === Hero Section === */
  .saas-hero {
    padding: 6rem 0 4rem;
    background: radial-gradient(circle at 80% -20%, rgba(25, 230, 203, 0.1), transparent 50%),
                var(--bg);
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1.2fr 1fr;
    }
  }

  .saas-hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
  }

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 300px;
  }

  .abstract-jars {
    position: relative;
    width: 200px;
    height: 200px;
  }

  .jar {
    position: absolute;
    width: 160px;
    height: 160px;
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    background: var(--bg-alt);
    top: 0; left: 20px;
    transform-origin: bottom center;
    transition: transform 0.5s ease;
  }

  .jar-1 { 
    transform: translateY(0) scale(1) translateZ(-40px); 
    opacity: 0.2; 
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .jar-label {
    color: var(--ink-faint);
    font-size: 1.5rem;
    font-weight: 700;
    font-family: var(--font-mono);
    text-transform: uppercase;
  }
  .jar-2 { transform: translateY(15px) scale(0.95) translateZ(-20px); opacity: 0.4; border-color: rgba(25, 230, 203, 0.2); }
  .jar-3 { transform: translateY(30px) scale(0.9); opacity: 0.8; border-color: rgba(25, 230, 203, 0.4); }

  .delta-block {
    position: absolute;
    bottom: -30px;
    left: 10px;
    width: 180px;
    padding: 1.5rem;
    background: rgba(25, 230, 203, 0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--brand);
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(25, 230, 203, 0.2);
    text-align: center;
    z-index: 10;
  }

  .delta-stat {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: var(--brand);
    line-height: 1;
    font-family: var(--font-mono);
  }

  .delta-label {
    display: block;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand-dark);
    margin-top: 0.5rem;
  }

  /* === Rhythm & Layouts === */
  .in-progress,
  .playbook,
  .cta {
    margin: 8rem 0; /* Huge rhythm spacing */
  }

  /* === In Progress Grid === */
  .in-progress-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .in-progress-grid {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }

  .glass-card {
    background: var(--bg-card);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--rule);
    border-radius: 16px;
    padding: 2rem;
    box-shadow: var(--shadow-md);
  }

  .card-title {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-soft);
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 0.5rem;
  }

  .case-study-link {
    margin-top: 2rem;
    font-weight: 600;
  }

  /* === Playbook Grid === */
  .playbook-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin: 3rem 0;
  }

  @media (min-width: 768px) {
    .playbook-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .playbook-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .playbook-step {
    background: var(--bg-alt);
    border: 1px solid var(--rule);
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .playbook-step:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--brand-soft);
  }

  .step-number {
    font-family: var(--font-mono);
    font-size: 3rem;
    font-weight: 800;
    color: var(--rule-strong);
    line-height: 1;
    margin-bottom: 1rem;
    transition: color 0.2s ease;
  }

  .playbook-step:hover .step-number {
    color: var(--brand);
  }

  .playbook-step h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    color: var(--ink-strong);
  }

  .playbook-step p {
    font-size: 0.95rem;
    color: var(--ink-soft);
    margin: 0;
  }

  .playbook-footer {
    text-align: center;
    max-width: var(--measure);
    margin: 0 auto;
    color: var(--ink-faint);
  }
</style>
