---
// /regulated — v5 plan §4.3.
// Encryption + key custody story for regulated buyers (banks,
// gov, research). Beshu customer-segment block above the fold,
// full testimonials, technical sections, 4-week evaluation
// framework. Dropped consultancy CTA per v5; routes to commercial
// license + production support instead.

import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import TestimonialsBlock from '../components/TestimonialsBlock.astro';
import CustomerSegmentBlock from '../components/CustomerSegmentBlock.astro';
import { webPageSchema, breadcrumbListSchema } from '../lib/seo';

const title =
  'DeltaGlider for regulated buyers — encrypt-before-the-backend on cheap S3-compatible storage';
const description =
  'AES-256-GCM encryption before objects hit the bucket. Your key stays in your runtime. The backend sees ciphertext. Built by Beshu Tech — the team behind ReadonlyREST, trusted since 2017 by CERN, EU institutions, and 2× of the S&P 500 top 5.';
---

<BaseLayout title={title} description={description}>
  <Fragment slot="json-ld">
    <JsonLd schema={webPageSchema({ path: '/regulated', title, description })} />
    <JsonLd
      schema={breadcrumbListSchema([
        { name: 'DeltaGlider', path: '/' },
        { name: 'For regulated buyers', path: '/regulated' },
      ])}
    />
  </Fragment>
  <section class="hero">
    <div class="shell reg-hero-grid">
      <div class="reg-hero-copy">
        <h1>Use cheap S3-compatible storage without giving the provider your data.</h1>

        <p class="hero-lede">
          DeltaGlider encrypts every object with AES-256-GCM before it
          reaches the bucket. Your encryption key lives in your runtime;
          the storage provider — Hetzner, Wasabi, Cloudflare, an offshore
          mirror — sees ciphertext only.
        </p>

        <p>
          Built by <a href="https://beshu.tech">Beshu Tech</a> — 10 senior
          engineers, since 2017. Same team behind
          <a href="https://readonlyrest.com">ReadonlyREST</a> (Elasticsearch
          security) and Anaphora (dashboard-to-PDF reporting), in production
          at:
        </p>
      </div>

      <div class="enc-visual" aria-hidden="true">
        <div class="enc-pane enc-pane--yours">
          <span class="enc-tag">Your runtime</span>
          <div class="enc-file">
            <span class="enc-file-icon">▤</span>
            acme-db-20260611.dump · 2.1 GB
          </div>
          <div class="enc-keyrow">
            <span class="enc-key-chip">⚿ AES-256 key</span>
            <span class="enc-key-note">lives here. Never uploaded.</span>
          </div>
        </div>

        <div class="enc-arrow">
          <span class="enc-arrow-label">encrypt, then upload</span>
          <span class="enc-arrow-line"></span>
        </div>

        <div class="enc-pane enc-pane--theirs">
          <span class="enc-tag enc-tag--theirs">What the provider stores</span>
          <pre class="enc-cipher">9f 2e 41 c7 88 0a d3 5b 6c e1 74 92 fb 08 1d a6
33 c9 5e 07 b4 8f 2a d1 66 0b 9c e8 45 71 af 12
de 60 3b f5 9a 04 c2 77 18 8d eb 56 a3 0f c4 29</pre>
          <span class="enc-cipher-note">ciphertext only — on Hetzner, Wasabi, anywhere</span>
        </div>
      </div>
    </div>
  </section>

  <div class="shell content-layout">
    <main class="main-content">
      <section class="encryption">
        <h2>How the encryption works</h2>

        <ul>
          <li>AES-256-GCM, per-object IV, applied after delta compression</li>
          <li>
            Four modes, set per backend: <code>none</code>,
            <code>aes256-gcm-proxy</code>, <code>sse-kms</code>,
            <code>sse-s3</code>. No SSE-C.
          </li>
          <li>
            In proxy-AES mode the key is supplied per backend — env var
            or <code>{'${env:...}'}</code> reference — and stripped from
            config exports. The backend (S3, Hetzner, Wasabi, etc.) sees
            ciphertext only.
          </li>
          <li>
            Key rotation is per backend, not in-place: the old key stays
            as a decrypt-only shim while a background re-encrypt job
            rewrites historical objects, then you delete it. Writes to a
            bucket being re-encrypted get 503 until the job finishes;
            reads pass.
          </li>
          <li>
            Every S3 operation lands in the structured stdout log. There
            is no per-decrypt audit event in proxy-AES mode — the key
            never leaves the process, so there's nothing to log it
            against. If you need "who decrypted what, when," use
            <code>sse-kms</code> and read CloudTrail.
          </li>
        </ul>
      </section>

      <section class="key-custody">
        <h2>How key custody stays in your runtime</h2>

        <ul>
          <li>
            Proxy runs in YOUR VPC / on YOUR Kubernetes / on YOUR bare
            metal
          </li>
          <li>In proxy-AES mode, the encryption key never leaves the proxy process</li>
          <li>Backend credentials never leave the proxy process</li>
          <li>No phone-home, no telemetry, no SaaS dependency</li>
          <li>Source code is GPL-3.0 — your security team can read every line</li>
        </ul>
      </section>

      <section class="not-claiming">
        <h2>What we don't claim</h2>

        <ul>
          <li>
            <strong>"SOC 2 compliant"</strong> — DeltaGlider produces audit
            logs you can ship into a SOC-2-attested SIEM. The proxy itself
            is software, not a compliance regime.
          </li>
          <li>
            <strong>"FIPS 140-3 validated"</strong> — we use the RustCrypto
            <code>aes-gcm</code> crate for AES-256-GCM. If you need FIPS,
            ship the FIPS-validated crypto layer underneath us.
          </li>
          <li>
            <strong>"GDPR-compliant"</strong> — DeltaGlider supports
            right-to-be-forgotten propagation via replication-delete and
            lifecycle expiration. The compliance regime is your problem;
            the technical primitives are ours.
          </li>
        </ul>
      </section>

      <section class="evaluation">
        <h2>How a regulated buyer evaluates DeltaGlider</h2>

        <p><strong>Week 1.</strong> Code review. The proxy is open
        source (GPL-3.0). The encryption module is in
        <code>src/storage/encrypting.rs</code>. The IAM model is in
        <code>src/iam/</code>. The admin API surface is in
        <code>src/api/admin/</code>. Your security team's questions:
        <a href="mailto:contact@beshu.tech">contact@beshu.tech</a>.</p>

        <p><strong>Week 2.</strong> Dev-environment deployment. Point a
        test bucket at the proxy. Run your existing security automation
        against it (key rotation, audit log validation, IdP integration
        smoke).</p>

        <p><strong>Week 3.</strong> Small production pilot on one
        non-critical bucket.</p>

        <p><strong>Week 4.</strong> Full deployment plan with Beshu
        engineering support — via the 30-day production support trial.</p>
      </section>

      <section class="cta">
        <h2>Talk to sales</h2>

        <p>
          Buying for a regulated environment? Talk to us about a
          commercial license and production support. Both are tailored
          to your jurisdiction, audit posture, and procurement workflow.
        </p>

        <div class="hero-ctas">
          <a
            href="mailto:contact@beshu.tech?subject=DeltaGlider%20-%20Regulated%20buyer%20inquiry"
            class="btn btn-primary"
          >
            Email contact@beshu.tech
          </a>
          <a href="/trial" class="btn">Start with the 30-day trial</a>
        </div>
      </section>
    </main>

    <aside class="social-proof-sidebar">
      <div class="sidebar-sticky compact-social">
        <CustomerSegmentBlock />
        <TestimonialsBlock />
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  /* === Hero: copy left, encryption-flow visual right === */
  .reg-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .reg-hero-grid { grid-template-columns: 1.05fr 0.95fr; gap: 4rem; }
  }

  .reg-hero-copy h1 {
    max-width: 22ch;
    font-size: clamp(2.2rem, 3.6vw, 3.3rem);
  }

  .enc-visual {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .enc-pane {
    border-radius: 16px;
    padding: 1.8rem 2rem;
    border: 1px solid var(--rule-strong);
    background: var(--bg-card);
    box-shadow: var(--shadow-md);
  }

  .enc-pane--yours {
    border-color: rgba(34, 211, 238, 0.45);
    box-shadow: 0 0 28px rgba(34, 211, 238, 0.14), var(--shadow-md);
  }

  .enc-tag {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--brand-dark);
    margin-bottom: 1rem;
  }
  .enc-tag--theirs { color: var(--ink-faint); }

  .enc-file {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-size: 1.05rem;
    color: var(--ink-strong);
    padding: 0.85rem 1rem;
    border: 1px solid var(--rule);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.03);
    margin-bottom: 0.9rem;
    white-space: nowrap;
    overflow: hidden;
  }
  .enc-file-icon { color: var(--brand); font-size: 1.25rem; }

  .enc-keyrow {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
  }
  .enc-key-chip {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 700;
    color: #fcd34d;
    padding: 0.45rem 0.8rem;
    border: 1px solid rgba(252, 211, 77, 0.4);
    border-radius: 999px;
    background: rgba(252, 211, 77, 0.08);
  }
  .enc-key-note { color: var(--ink-soft); font-size: 0.95rem; }

  .enc-arrow {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0 0.5rem;
  }
  .enc-arrow-label {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--brand-dark);
    white-space: nowrap;
  }
  .enc-arrow-line {
    flex: 1;
    height: 2px;
    background: linear-gradient(90deg, rgba(34, 211, 238, 0.7), var(--rule));
    position: relative;
  }
  .enc-arrow-line::after {
    content: '';
    position: absolute;
    right: -1px;
    top: 50%;
    transform: translateY(-50%);
    border-left: 8px solid var(--rule-strong);
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
  }

  .enc-cipher {
    margin: 0 0 0.8rem;
    padding: 1rem 1.1rem;
    font-size: 0.98rem;
    line-height: 1.8;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid var(--rule);
    border-radius: 10px;
    box-shadow: none;
    overflow: hidden;
  }
  .enc-cipher-note {
    font-size: 0.95rem;
    color: var(--ink-soft);
  }

  .content-layout {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    margin-top: 3rem;
  }

  @media (min-width: 1024px) {
    .content-layout {
      flex-direction: row;
      gap: 5rem;
      align-items: flex-start;
    }

    .main-content {
      flex: 1;
      min-width: 0;
    }

    .social-proof-sidebar {
      width: 380px;
      flex-shrink: 0;
      background: rgba(15, 23, 42, 0.3);
      border: 1px solid var(--rule);
      border-radius: 12px;
      padding: 1.5rem;
      box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.2);
    }

    .sidebar-sticky {
      position: sticky;
      top: 2rem;
    }
  }

  .encryption,
  .key-custody,
  .not-claiming,
  .evaluation,
  .cta {
    margin-bottom: 4rem;
  }

  /* Compact the social blocks within the sidebar */
  .compact-social :global(.segment-list),
  .compact-social :global(.testimonials-grid) {
    grid-template-columns: 1fr !important;
  }

  .compact-social :global(.customer-segments),
  .compact-social :global(.testimonials) {
    margin: 0 0 2rem 0;
  }

  .compact-social :global(h2) {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    border: none;
    padding: 0;
  }

  .compact-social :global(.segment-lede),
  .compact-social :global(.testimonials-framing) {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .compact-social :global(.segment-list li) {
    padding: 0.5rem 0.75rem;
    font-size: 0.9rem;
  }
</style>
