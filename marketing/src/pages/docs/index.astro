---
// /docs — the documentation landing. Groups + ordering come from the shared
// manifest, so it mirrors the in-product docs landing exactly.
import DocsLayout from '../../layouts/DocsLayout.astro';
import Glyph from '../../components/Glyph.astro';
import { docsByGroup } from '../../lib/docs';

const groups = docsByGroup();

// Group id → pictogram (see Glyph.astro for the set).
const GROUP_GLYPHS: Record<string, any> = {
  'Start here': 'flag',
  'Guides: deploy & operate': 'wrench',
  'Guides: storage & data': 'replicate',
  'Guides: access & security': 'shield-key',
  'Reference': 'book',
  'Concepts': 'bulb',
};
---

<DocsLayout
  title="Documentation — DeltaGlider Proxy"
  description="DeltaGlider Proxy documentation: tutorials, how-to guides, reference, and concepts. The same docs that ship inside the product."
  activeSlug=""
>
  <header class="docs-landing-head">
    <h1>Documentation</h1>
    <p>
      Everything you need to run DeltaGlider Proxy — the same docs bundled into
      the product, served here for easy linking.
    </p>
  </header>

  {groups.map((g) => (
    <section class="docs-landing-group">
      <h2 class="docs-landing-group-title">
        <Glyph name={GROUP_GLYPHS[g.group.id] ?? 'book'} size={30} />
        <span>{g.group.id}</span>
      </h2>
      <p class="docs-landing-tagline">{g.group.tagline}</p>
      <ul class="docs-landing-list">
        {g.docs.filter((d) => d.slug !== '').map((d) => (
          <li>
            <a href={d.url}>{d.title}</a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</DocsLayout>
