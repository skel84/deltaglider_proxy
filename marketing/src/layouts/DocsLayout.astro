---
// DocsLayout.astro — shell for every /docs page: BaseLayout chrome + a
// grouped sidebar (driven by the shared manifest) + the doc content slot +
// an optional right-rail TOC (named `toc` slot; only when hasToc is true).
// The sidebar order/grouping is identical to the in-product docs viewer
// because both read docs/product/manifest.json.
//
// Display type ("Technical logbook" direction): Schibsted Grotesk for doc
// headings + Spline Sans Mono for the logbook labels (eyebrows, §/# markers,
// breadcrumb, TOC). Loaded via the BaseLayout `head` slot so the two extra
// families only ship on /docs pages, not the whole marketing site.

import BaseLayout from './BaseLayout.astro';
import { docsByGroup } from '../lib/docs';
import '../styles/docs.css';

interface Props {
  title: string;
  description: string;
  /** Friendly slug of the current doc ('' for the landing) — highlights the nav. */
  activeSlug: string;
  /** Render the 3-column layout with a right-rail TOC. */
  hasToc?: boolean;
}

const { title, description, activeSlug, hasToc = false } = Astro.props;
const groups = docsByGroup();
---

<BaseLayout title={title} description={description} ogType="article">
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@500;600;700;800&family=Spline+Sans+Mono:wght@500;600&display=swap"
      rel="stylesheet"
    />
    {/* Pagefind UI styles (bundle built by the postbuild step; 404 on dev). */}
    <link href="/_pagefind/pagefind-ui.css" rel="stylesheet" />
  </Fragment>

  <div class={`docs-shell${hasToc ? ' has-toc' : ''}`}>
    <aside class="docs-sidebar" aria-label="Documentation" data-pagefind-ignore role="complementary">
      <a href="/docs" class={`docs-nav-home${activeSlug === '' ? ' is-active' : ''}`}>
        Documentation
      </a>

      {/* Pagefind search. The #pagefind-search container is hydrated by the
          script below once /_pagefind/ exists (built by the postbuild step).
          The button is the keyboard/click affordance; results render in a
          modal overlay. Progressive: if the bundle is absent (dev server),
          the button is hidden so nothing looks broken. */}
      <button
        type="button"
        id="docs-search-btn"
        class="docs-search-btn"
        aria-label="Search docs"
        hidden
      >
        <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6">
          <circle cx="7" cy="7" r="4.5" /><path d="M11 11l3.5 3.5" stroke-linecap="round" />
        </svg>
        <span>Search</span>
        <kbd class="docs-search-kbd">⌘K</kbd>
      </button>

      <nav class="docs-nav-groups" aria-label="Documentation sections">
      {groups.map((g) => {
        const items = g.docs.filter((d) => d.slug !== '');
        // Open the group that contains the current page; others start open too
        // on first load (no stored state yet) but collapse on click. A reader
        // never lands on a doc whose group is shut.
        const hasActive = items.some((d) => d.slug === activeSlug);
        return (
          <details class="docs-nav-group" data-group={g.group.id} data-has-active={hasActive ? 'true' : undefined} open>
            <summary class="docs-nav-group-title">
              <span>{g.group.id}</span>
              <svg class="docs-nav-chevron" viewBox="0 0 16 16" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 6l4 4 4-4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </summary>
            <ul class="docs-nav-children">
              {items.map((d) => (
                <li>
                  <a
                    href={d.url}
                    class={d.slug === activeSlug ? 'is-active' : undefined}
                    aria-current={d.slug === activeSlug ? 'page' : undefined}
                  >{d.title}</a>
                </li>
              ))}
            </ul>
          </details>
        );
      })}
      </nav>

      {/* Version signal: the public site is built from `main`, so it can be
          ahead of a tagged release a reader is running. Point them at the
          release notes to reconcile. */}
      <p class="docs-version-badge">
        <span class="docs-version-dot" aria-hidden="true"></span>
        Docs track <code>main</code> ·
        <a href="https://github.com/beshu-tech/deltaglider_proxy/releases" target="_blank" rel="noopener">release notes</a>
      </p>
    </aside>

    <article class="docs-content">
      <slot />
    </article>

    {hasToc && <slot name="toc" />}
  </div>

  {/* Search overlay — Pagefind's default UI mounts into #pagefind-search. */}
  <div id="docs-search-overlay" class="docs-search-overlay" hidden data-pagefind-ignore>
    <div class="docs-search-modal" role="dialog" aria-modal="true" aria-label="Search docs">
      <div id="pagefind-search"></div>
    </div>
  </div>

  {/* is:inline so Astro/Vite don't try to bundle-resolve the /_pagefind/
      import at build time — that bundle is generated AFTER the build by the
      postbuild Pagefind step, so it can't be statically analyzed. */}
  <script is:inline>
    // Lazy-load Pagefind's UI only when the user opens search. The bundle
    // lives at /_pagefind/ (built by `pagefind --site dist` postbuild). On
    // the dev server those assets don't exist, so we feature-detect and keep
    // the button hidden — search is a production-build affordance.
    (function () {
      var btn = document.getElementById('docs-search-btn');
      var overlay = document.getElementById('docs-search-overlay');
      if (!btn || !overlay) return;
      var booted = false;
      var bundle = '/_pagefind/pagefind-ui.js';

      function open() {
        var ready = Promise.resolve();
        if (!booted) {
          booted = true;
          // pagefind-ui.js is a UMD bundle: importing it for its side effect
          // registers `window.PagefindUI` rather than an ESM export, so we read
          // the constructor off the global once the module has run. Dynamic
          // import via a runtime var so Vite leaves the path alone at build.
          ready = import(/* @vite-ignore */ bundle).then(function (mod) {
            var UI = (mod && mod.PagefindUI) || window.PagefindUI;
            new UI({
              element: '#pagefind-search',
              // The index + wasm engine live under /_pagefind/ (we build with
              // --output-subdir _pagefind). Without this, the UI defaults to
              // loading the engine from /pagefind/ and the fetch 404s.
              bundlePath: '/_pagefind/',
              showImages: false,
              showSubResults: true,
              resetStyles: false,
            });
          });
        }
        ready.then(function () {
          overlay.hidden = false;
          var input = overlay.querySelector('input.pagefind-ui__search-input');
          if (input) input.focus();
        });
      }
      function close() { overlay.hidden = true; }

      // Only reveal the button if the bundle actually shipped.
      fetch(bundle, { method: 'HEAD' })
        .then(function (r) { if (r.ok) btn.hidden = false; })
        .catch(function () { /* dev server: leave hidden */ });

      btn.addEventListener('click', open);
      overlay.addEventListener('click', function (e) { if (e.target === overlay) close(); });
      document.addEventListener('keydown', function (e) {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          if (btn.hidden) return;
          overlay.hidden ? open() : close();
        } else if (e.key === 'Escape' && !overlay.hidden) {
          close();
        }
      });
    })();
  </script>

  {/* Sidebar group collapse/expand persistence. Groups render open (good
      no-JS fallback); this restores each group's last open/closed state and
      remembers changes. The group containing the current page is always forced
      open so a reader never lands on a doc inside a collapsed group. */}
  <script is:inline>
    (function () {
      var KEY = 'dg-docs-nav-collapsed';
      var groups = document.querySelectorAll('.docs-nav-group[data-group]');
      if (!groups.length) return;

      var collapsed = {};
      try { collapsed = JSON.parse(localStorage.getItem(KEY) || '{}') || {}; } catch (e) {}

      groups.forEach(function (g) {
        var id = g.getAttribute('data-group');
        if (g.getAttribute('data-has-active') === 'true') {
          g.open = true; // never hide the active page's group
        } else if (collapsed[id]) {
          g.open = false;
        }
        g.addEventListener('toggle', function () {
          if (g.open) delete collapsed[id]; else collapsed[id] = true;
          try { localStorage.setItem(KEY, JSON.stringify(collapsed)); } catch (e) {}
        });
      });
    })();
  </script>
</BaseLayout>
