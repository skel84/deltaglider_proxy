---
// DocsLayout.astro — shell for every /docs page: BaseLayout chrome + a
// grouped sidebar (driven by the shared manifest) + the doc content slot +
// an optional right-rail TOC (named `toc` slot; only when hasToc is true).
// The sidebar order/grouping is identical to the in-product docs viewer
// because both read docs/product/manifest.json.
//
// Display type ("Technical logbook" direction): Schibsted Grotesk for doc
// headings + Spline Sans Mono for the logbook labels (eyebrows, §/# markers,
// breadcrumb, TOC). Loaded via the BaseLayout `head` slot so the two extra
// families only ship on /docs pages, not the whole marketing site.

import BaseLayout from './BaseLayout.astro';
import { docsByGroup } from '../lib/docs';
import '../styles/docs.css';

interface Props {
  title: string;
  description: string;
  /** Friendly slug of the current doc ('' for the landing) — highlights the nav. */
  activeSlug: string;
  /** Render the 3-column layout with a right-rail TOC. */
  hasToc?: boolean;
}

const { title, description, activeSlug, hasToc = false } = Astro.props;
const groups = docsByGroup();
---

<BaseLayout title={title} description={description} ogType="article">
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@500;600;700;800&family=Spline+Sans+Mono:wght@500;600&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class={`docs-shell${hasToc ? ' has-toc' : ''}`}>
    <aside class="docs-sidebar" aria-label="Documentation">
      <a href="/docs" class={`docs-nav-home${activeSlug === '' ? ' is-active' : ''}`}>
        Documentation
      </a>
      {groups.map((g) => (
        <div class="docs-nav-group">
          <div class="docs-nav-group-title">{g.group.id}</div>
          <ul>
            {g.docs.filter((d) => d.slug !== '').map((d) => (
              <li>
                <a
                  href={d.url}
                  class={d.slug === activeSlug ? 'is-active' : undefined}
                  aria-current={d.slug === activeSlug ? 'page' : undefined}
                >{d.title}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </aside>

    <article class="docs-content">
      <slot />
    </article>

    {hasToc && <slot name="toc" />}
  </div>
</BaseLayout>
