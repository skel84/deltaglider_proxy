---
// BaseLayout.astro — shell every page extends.
// Per the v5 plan §7 visual brief: anti-polish but designed. One brand
// color (teal), one accent, real typography, real chrome.
//
// Inline logo SVG matches the favicon (teal lightning bolt on navy
// rounded square). Brand wordmark uses Manrope (Google Fonts, swap).
// Mono / code blocks use self-hosted JetBrains Mono (OFL).

import '../styles/global.css';
import { SITE } from '../lib/seo';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  canonical,
  ogImage = SITE.ogImage,
  ogType = 'website',
} = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Manrope — variable display sans. font-display:swap inherited. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="DeltaGlider" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="DeltaGlider — Storage compression for S3, behind the same S3 API." />
    <meta property="og:locale" content="en_GB" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="DeltaGlider — Storage compression for S3, behind the same S3 API." />

    <meta name="generator" content={Astro.generator} />

    <slot name="json-ld" />
    {/* Page-scoped head extras (e.g. docs-only display fonts). */}
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary">
        <a href="/" class="brand" aria-label="DeltaGlider home">
          <svg
            class="brand-mark"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 64 64"
            aria-hidden="true"
          >
            <polygon points="12,46 32,16 52,46 40,46 32,34 24,46" fill="var(--brand)" />
          </svg>
          <span>
            <span class="brand-mute">Beshu</span>
            DeltaGlider
          </span>
        </a>
        <ul class="site-nav-links">
          <li><a href="/saas">SaaS</a></li>
          <li><a href="/regulated">Regulated</a></li>
          <li><a href="/pricing">Pricing</a></li>
          <li><a href="/trial">Trial</a></li>
          <li><a href="https://github.com/beshu-tech/deltaglider_proxy">GitHub</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer" aria-label="Footer">
      <div class="footer-grid">
        <div>
          <div class="footer-brand-row">
            <svg
              class="brand-mark"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 64 64"
              aria-hidden="true"
            >
              <polygon points="12,46 32,16 52,46 40,46 32,34 24,46" fill="var(--brand)" />
            </svg>
            <span>DeltaGlider</span>
          </div>
          <p class="footer-tagline">
            Storage compression for S3, behind the same S3 API.
            Open source (GPL-3.0).
          </p>
        </div>

        <div class="footer-col">
          <h4 class="footer-col-title">Product</h4>
          <ul>
            <li><a href="/saas">For SaaS</a></li>
            <li><a href="/regulated">For regulated</a></li>
            <li><a href="/pricing">Pricing</a></li>
            <li><a href="/trial">30-day trial</a></li>
            <li><a href="/case-studies">Case studies</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4 class="footer-col-title">Resources</h4>
          <ul>
            <li><a href="https://github.com/beshu-tech/deltaglider_proxy">GitHub</a></li>
            <li><a href="/docs/quickstart">Quickstart</a></li>
            <li><a href="/docs/reference">Reference docs</a></li>
            <li><a href="mailto:contact@beshu.tech?subject=DeltaGlider%20-%20General%20inquiry">Contact</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4 class="footer-col-title">Beshu Tech</h4>
          <ul>
            <li><a href="https://beshu.tech">beshu.tech</a></li>
            <li><a href="https://readonlyrest.com">ReadonlyREST</a></li>
            <li><a href="https://anaphora.beshu.tech">Anaphora</a></li>
          </ul>
        </div>
      </div>

      <div class="footer-bottom">
        <span>© Beshu Limited · GPL-3.0 · London, UK</span>
        <span>
          Interested in a managed cloud offering?
          <a href="mailto:contact@beshu.tech?subject=DeltaGlider%20-%20Managed%20cloud%20interest">Let us know</a>
          — evaluating for Q4 2026.
        </span>
      </div>
    </footer>
  </body>
</html>
