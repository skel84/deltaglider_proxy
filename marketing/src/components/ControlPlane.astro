---
// ControlPlane.astro — "the other half of the product" section.
// v2: the art-directed bento (fake policy JSON, glowing flowmap, lopsided
// tall tile) is gone — decorative mock-UI sitting above REAL screenshots
// always loses. Now: a plain editorial feature list, then the evidence —
// three real admin-UI screens with always-visible captions and a lightbox
// with prev/next navigation.
const features = [
  {
    glyph: 'shield-key',
    title: 'Per-user auth & access control',
    desc: 'IAM with fine-grained ABAC permissions, plus OAuth/OIDC SSO with group mapping — an access layer your budget object store doesn’t have.',
  },
  {
    glyph: 'replicate',
    title: 'Cross-cloud replication',
    desc: 'Replicate buckets between providers — event-driven or scheduled, with pause/resume. Migrate or run multi-cloud, without lock-in.',
  },
  {
    glyph: 'lock',
    title: 'Encryption at rest',
    desc: 'AES-256-GCM before objects hit the bucket. Your key stays in your runtime; the backend only ever sees ciphertext.',
  },
  {
    glyph: 'pulse',
    title: 'Jobs, events & audit',
    desc: 'Replication, lifecycle, migrations, and re-encryption run as resumable jobs with run history. Webhook or Slack on every event; an audit trail on every admin action.',
  },
] as const;

const shots = [
  {
    src: '/screenshots/iam.jpg',
    alt: 'IAM user management screen in the embedded admin UI',
    caption: 'IAM users with ABAC permissions and group mapping.',
  },
  {
    src: '/screenshots/object-replication.jpg',
    alt: 'Jobs screen showing replication and lifecycle rules',
    caption: 'One Jobs screen: replication, lifecycle, migrations.',
  },
  {
    src: '/screenshots/analytics.jpg',
    alt: 'Storage analytics dashboard with per-bucket savings',
    caption: 'Per-bucket savings, measured live — not estimated.',
  },
];
import Glyph from './Glyph.astro';
---

<section class="section cp" aria-labelledby="cp-title">
  <div class="shell">
    <header class="cp-head">
      <span class="section-eyebrow">The other half</span>
      <h2 id="cp-title" class="cp-title">
        It's also the control plane your cheap bucket is missing
      </h2>
      <p class="cp-intro">
        The compression pays for the move; this is why you stay. Point it
        at Hetzner, Wasabi, MinIO, or AWS and the governance you'd
        normally rent from a hyperscaler rides along in the same binary.
      </p>
    </header>

    <div class="feat-grid">
      {features.map((f, i) => (
        <div class="feat">
          <Glyph name={f.glyph} size={42} />
          <div class="feat-body">
            <span class="feat-idx">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="feat-title">{f.title}</h3>
            <p class="feat-desc">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <p class="cp-proof-lede">
      None of it is a separate product: these screens ship inside the
      binary you download. Click to inspect.
    </p>
    <div class="shots">
      {shots.map((s) => (
        <figure class="shot">
          <button class="shot-frame" type="button" data-src={s.src} data-alt={s.alt} aria-label={`Enlarge screenshot: ${s.caption}`}>
            <img src={s.src} alt={s.alt} width="1147" height="1440" loading="lazy" decoding="async" />
          </button>
          <figcaption class="shot-caption">{s.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<dialog id="cp-lightbox" class="lightbox">
  <form method="dialog" class="lightbox-close-wrapper">
    <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
  </form>
  <button id="cp-lightbox-prev" class="lightbox-nav lightbox-nav--prev" type="button" aria-label="Previous screenshot">&#8249;</button>
  <img id="cp-lightbox-img" src="" alt="" loading="lazy" />
  <button id="cp-lightbox-next" class="lightbox-nav lightbox-nav--next" type="button" aria-label="Next screenshot">&#8250;</button>
</dialog>

<script>
  const frames = Array.from(document.querySelectorAll('.shot-frame'));
  const dialog = document.getElementById('cp-lightbox') as HTMLDialogElement;
  const img = document.getElementById('cp-lightbox-img') as HTMLImageElement;
  const prevBtn = document.getElementById('cp-lightbox-prev');
  const nextBtn = document.getElementById('cp-lightbox-next');

  if (frames.length > 0 && dialog && img && prevBtn && nextBtn) {
    let current = 0;

    const show = (i: number) => {
      current = (i + frames.length) % frames.length;
      const frame = frames[current];
      img.src = frame.getAttribute('data-src') || '';
      img.alt = frame.getAttribute('data-alt') || '';
    };

    frames.forEach((frame, i) => {
      frame.addEventListener('click', () => {
        show(i);
        dialog.showModal();
      });
    });

    prevBtn.addEventListener('click', (e) => { e.stopPropagation(); show(current - 1); });
    nextBtn.addEventListener('click', (e) => { e.stopPropagation(); show(current + 1); });

    dialog.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); show(current - 1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); show(current + 1); }
    });

    dialog.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (t.closest('.lightbox-nav') || t.closest('.lightbox-close-wrapper')) return;
      const r = img.getBoundingClientRect();
      if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) {
        dialog.close();
      }
    });
  }
</script>

<style>
  /* ---------- header ---------- */
  .cp-head {
    max-width: 680px;
    margin-bottom: 2.75rem;
  }
  .cp-title {
    margin-top: 0.7rem;
  }
  .cp-intro {
    font-size: clamp(1rem, 1.4vw, 1.1rem);
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
    max-width: 60ch;
  }

  /* ---------- editorial feature grid ---------- */
  .feat-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem 3rem;
    max-width: var(--measure-wide);
  }
  @media (min-width: 720px) {
    .feat-grid { grid-template-columns: 1fr 1fr; }
  }

  .feat {
    border-top: 2px solid var(--rule-strong);
    padding-top: 1.4rem;
    display: flex;
    gap: 1.3rem;
    align-items: flex-start;
  }

  .feat-body { min-width: 0; }

  .feat-idx {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--brand-dark);
  }

  .feat-title {
    margin: 0.45rem 0 0.55rem;
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.015em;
    color: var(--ink-strong);
    line-height: 1.15;
  }

  .feat-desc {
    margin: 0;
    color: var(--ink-soft);
    font-size: 1.02rem;
    line-height: 1.6;
    max-width: none;
  }

  /* ---------- evidence strip ---------- */
  .cp-proof-lede {
    margin: 3rem 0 1.25rem;
    color: var(--ink-soft);
    font-size: 0.98rem;
    max-width: var(--measure-wide);
  }

  .shots {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.4rem;
  }
  @media (min-width: 700px) {
    .shots { grid-template-columns: repeat(3, 1fr); }
  }

  .shot { margin: 0; }

  .shot-frame {
    display: block;
    width: 100%;
    padding: 0;
    border: 1px solid var(--rule);
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg-soft);
    box-shadow: var(--shadow-sm);
    aspect-ratio: 4 / 3;
    cursor: zoom-in;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .shot-frame:hover {
    border-color: rgba(34, 211, 238, 0.45);
    box-shadow: var(--shadow-md);
  }
  .shot-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .shot-caption {
    margin-top: 0.6rem;
    font-size: 0.88rem;
    color: var(--ink-soft);
    line-height: 1.45;
  }

  /* ---------- lightbox ---------- */
  .lightbox {
    padding: 0;
    border: none;
    border-radius: 8px;
    background: transparent;
    max-width: 90vw;
    max-height: 90vh;
    overflow: visible;
  }
  .lightbox::backdrop {
    background: rgba(11, 15, 25, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .lightbox img {
    display: block;
    max-width: 100%;
    max-height: 90vh;
    border-radius: 8px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    object-fit: contain;
  }
  .lightbox-close-wrapper {
    position: absolute;
    top: -2rem;
    right: -2rem;
  }
  .lightbox-close {
    background: var(--bg-card);
    border: 1px solid var(--rule);
    color: var(--ink-strong);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--shadow-md);
    transition: all 0.2s ease;
  }
  .lightbox-close:hover {
    background: var(--brand);
    border-color: var(--brand);
    color: #0b0f19;
    transform: scale(1.1);
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid var(--rule);
    background: var(--bg-card);
    color: var(--ink-strong);
    font-size: 1.7rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-bottom: 0.2rem;
    cursor: pointer;
    box-shadow: var(--shadow-md);
    transition: all 0.2s ease;
  }
  .lightbox-nav--prev { left: -3.6rem; }
  .lightbox-nav--next { right: -3.6rem; }
  .lightbox-nav:hover {
    background: var(--brand);
    border-color: var(--brand);
    color: #0b0f19;
    transform: translateY(-50%) scale(1.1);
  }

  @media (max-width: 768px) {
    .lightbox-close-wrapper { top: 0.5rem; right: 0.5rem; }
    .lightbox-close { width: 32px; height: 32px; font-size: 1.2rem; }
    .lightbox-nav { width: 38px; height: 38px; font-size: 1.4rem; }
    .lightbox-nav--prev { left: 0.5rem; }
    .lightbox-nav--next { right: 0.5rem; }
  }
</style>
