---
// HowItWorks.astro — homepage "how it works" section.
// Sits as <section class="section"> right after the hero.
// Visual-first: one flow diagram (apps → proxy → S3) + three numbered steps.
// CSS-only, reduced-motion safe, responsive (diagram stacks on mobile).
---

<section class="section hiw">
  <div class="shell">
    <span class="section-eyebrow">How it works</span>
    <h2 class="hiw-title">Same S3 in. Tiny bytes stored.</h2>
    <p class="hiw-sub">
      A drop-in proxy that stores new versions as deltas, then rebuilds
      the exact bytes on read. Your apps never know.
    </p>

    {/* ===================== FLOW DIAGRAM ===================== */}
    <div class="flow" role="img"
      aria-label="Your apps send standard S3 requests to the DeltaGlider proxy, which stores a reference plus small deltas in your S3 bucket. A 90 megabyte version becomes a 148 kilobyte delta.">

      {/* — node: apps — */}
      <div class="node node-apps">
        <div class="node-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="3" y="4" width="18" height="12" rx="1.5"/>
            <path d="M8 20h8M12 16v4"/>
          </svg>
        </div>
        <div class="node-label">Your apps</div>
        <div class="node-mono">S3 · SigV4</div>
      </div>

      <div class="wire" aria-hidden="true">
        <span class="wire-mono">PUT / GET</span>
        <span class="wire-line"><span class="pulse"></span></span>
      </div>

      {/* — node: proxy (the magic) — */}
      <div class="node node-proxy">
        <div class="node-badge">DeltaGlider</div>
        <div class="bars" aria-hidden="true">
          <div class="bar-row">
            <span class="bar-tag">in</span>
            <span class="bar bar-full"><i style="--w:100%">v1</i><i style="--w:96%">v2</i><i style="--w:98%">v3</i></span>
          </div>
          <div class="bar-arrow">↓</div>
          <div class="bar-row">
            <span class="bar-tag">stored</span>
            <span class="bar bar-thin"><i class="ref" style="--w:100%">ref</i><i style="--w:9%">Δ</i><i style="--w:7%">Δ</i></span>
          </div>
        </div>
        <div class="node-saving"><b>90&nbsp;MB</b> &rarr; <b class="hl">148&nbsp;KB</b></div>
      </div>

      <div class="wire" aria-hidden="true">
        <span class="wire-mono">ref + Δ</span>
        <span class="wire-line"><span class="pulse pulse-2"></span></span>
      </div>

      {/* — node: bucket — */}
      <div class="node node-bucket">
        <div class="node-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <ellipse cx="12" cy="6" rx="8" ry="3"/>
            <path d="M4 6v12c0 1.7 3.6 3 8 3s8-1.3 8-3V6"/>
            <path d="M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3"/>
          </svg>
        </div>
        <div class="node-label">Your S3 bucket</div>
        <div class="node-mono">unchanged</div>
      </div>
    </div>

    {/* ===================== THREE STEPS ===================== */}
    <ol class="steps">
      <li class="step">
        <span class="step-num">01</span>
        <h3 class="step-head">Point your apps at it</h3>
        <p class="step-body">Same S3 endpoint, same SigV4 keys. Zero code changes.</p>
      </li>
      <li class="step">
        <span class="step-num">02</span>
        <h3 class="step-head">It stores deltas, not copies</h3>
        <p class="step-body">Each new version is saved as the diff from the last.</p>
      </li>
      <li class="step">
        <span class="step-num">03</span>
        <h3 class="step-head">Reads rebuild the original</h3>
        <p class="step-body">Every GET returns exact bytes. Transparent, lossless.</p>
      </li>
    </ol>
  </div>
</section>

<style>
  .hiw-title { margin-top: 0; }
  .hiw-sub {
    color: var(--ink-soft);
    max-width: 52ch;
    margin: 0 0 2.5rem;
    font-size: 1.05rem;
  }

  /* ===================== FLOW DIAGRAM ===================== */
  .flow {
    display: grid;
    grid-template-columns: 1fr auto 1.4fr auto 1fr;
    align-items: stretch;
    gap: 0;
    margin: 0 0 3.25rem;
  }

  .node {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.4rem 1rem;
    border: 1px solid var(--rule);
    border-radius: 14px;
    background: var(--bg-card);
    text-align: center;
    backdrop-filter: blur(6px);
  }

  .node-icon {
    width: 38px; height: 38px;
    color: var(--ink-soft);
  }
  .node-icon svg { width: 100%; height: 100%; }

  .node-label {
    font-weight: 700;
    color: var(--ink-strong);
    font-size: 0.98rem;
  }
  .node-mono {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-mute);
    letter-spacing: 0.02em;
  }

  /* --- proxy node: the hero of the diagram --- */
  .node-proxy {
    border-color: rgba(34, 211, 238, 0.45);
    background:
      radial-gradient(120% 120% at 50% 0%, rgba(34,211,238,0.10), transparent 70%),
      var(--bg-card);
    box-shadow: var(--shadow-glow);
    gap: 0.85rem;
    padding: 1.5rem 1.2rem;
  }
  .node-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--bg);
    background: var(--brand);
    padding: 0.22rem 0.7rem;
    border-radius: 999px;
  }

  .bars {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    width: 100%;
    max-width: 240px;
  }
  .bar-row {
    display: grid;
    grid-template-columns: 3.2rem 1fr;
    align-items: center;
    gap: 0.55rem;
    width: 100%;
  }
  .bar-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--ink-mute);
    text-align: right;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .bar { display: flex; gap: 4px; height: 22px; }
  .bar i {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    width: var(--w);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-style: normal;
    color: var(--ink-soft);
    overflow: hidden;
    transform-origin: left center;
    animation: grow-in 0.7s cubic-bezier(.2,.8,.2,1) both;
  }
  .bar-full i {
    background: rgba(148, 163, 184, 0.22);
    border: 1px solid var(--rule);
  }
  .bar-thin i {
    background: rgba(34, 211, 238, 0.18);
    border: 1px solid rgba(34, 211, 238, 0.4);
    color: var(--brand-dark);
    animation: shrink-in 0.8s cubic-bezier(.2,.8,.2,1) both;
  }
  .bar-thin i.ref {
    background: rgba(217, 70, 239, 0.16);
    border-color: rgba(217, 70, 239, 0.4);
    color: #f0abfc;
    animation: grow-in 0.7s cubic-bezier(.2,.8,.2,1) both;
  }
  .bar-arrow {
    color: var(--brand);
    font-size: 0.85rem;
    line-height: 1;
    margin-left: 3.75rem;
    align-self: start;
  }

  .node-saving {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--ink-soft);
  }
  .node-saving b { color: var(--ink-strong); font-weight: 600; }
  .node-saving .hl { color: var(--brand-dark); }

  /* --- wires between nodes --- */
  .wire {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0 0.75rem;
    min-width: 78px;
  }
  .wire-mono {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--ink-mute);
    letter-spacing: 0.02em;
  }
  .wire-line {
    position: relative;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, var(--rule), rgba(34,211,238,0.5));
    border-radius: 2px;
    overflow: visible;
  }
  .wire-line::after {
    content: '';
    position: absolute;
    right: -1px; top: 50%;
    transform: translateY(-50%);
    border-left: 6px solid var(--brand);
    border-top: 4px solid transparent;
    border-bottom: 4px solid transparent;
  }
  .pulse {
    position: absolute;
    top: 50%; left: 0;
    width: 7px; height: 7px;
    margin-top: -3.5px;
    border-radius: 50%;
    background: var(--brand-dark);
    box-shadow: 0 0 8px var(--brand);
    animation: travel 2.4s linear infinite;
  }
  .pulse-2 { animation-delay: 1.2s; }

  @keyframes travel {
    0%   { left: 0;    opacity: 0; }
    12%  { opacity: 1; }
    88%  { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }
  @keyframes grow-in {
    from { transform: scaleX(0); opacity: 0; }
    to   { transform: scaleX(1); opacity: 1; }
  }
  @keyframes shrink-in {
    0%   { transform: scaleX(1); opacity: 0.4; background: rgba(148,163,184,0.22); }
    100% { transform: scaleX(1); opacity: 1; }
  }

  /* ===================== THREE STEPS ===================== */
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .step {
    position: relative;
    padding: 1.4rem 1.4rem 1.5rem;
    border: 1px solid var(--rule);
    border-radius: 14px;
    background: var(--bg-card);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .step:hover {
    border-color: rgba(34, 211, 238, 0.4);
    transform: translateY(-2px);
  }
  .step-num {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--brand);
  }
  .step-head {
    margin: 0.45rem 0 0.4rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink-strong);
  }
  .step-body {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.92rem;
    max-width: none;
  }

  /* ===================== RESPONSIVE ===================== */
  @media (max-width: 860px) {
    .flow {
      grid-template-columns: 1fr;
      gap: 0;
      max-width: 360px;
      margin-inline: auto;
    }
    .wire {
      flex-direction: row;
      min-width: 0;
      padding: 0.55rem 0;
      gap: 0.6rem;
    }
    .wire-line {
      width: 2px;
      height: 26px;
      background: linear-gradient(180deg, var(--rule), rgba(34,211,238,0.5));
    }
    .wire-line::after {
      right: 50%; top: auto; bottom: -1px;
      transform: translateX(50%);
      border-left: 4px solid transparent;
      border-right: 4px solid transparent;
      border-top: 6px solid var(--brand);
      border-bottom: 0;
    }
    .pulse { animation: travel-v 2.4s linear infinite; }
    @keyframes travel-v {
      0% { top: 0; opacity: 0; } 12% { opacity: 1; }
      88% { opacity: 1; } 100% { top: 100%; opacity: 0; }
    }
  }
  @media (max-width: 620px) {
    .steps { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse { display: none; }
    .bar i, .bar-thin i { animation: none !important; }
    .step { transition: none; }
  }
</style>
