---
// ScreenshotGallery — visual proof of the admin UI.
// Per v5 §7 anti-polish: real screenshots, descriptive alt text, no decoration.

interface Screenshot {
  src: string;
  alt: string;
  title: string;
  description: string;
}

const screenshots: Screenshot[] = [
  {
    src: '/screenshots/iam.jpg',
    alt: 'IAM user management',
    title: 'Identity & access management',
    description: 'Fine-grained ABAC permissions for users and groups. Map directly to OAuth roles and policies.',
  },
  {
    src: '/screenshots/object-replication.jpg',
    alt: 'Object replication',
    title: 'Cross-bucket replication',
    description: 'Event-driven or scheduled replication between S3, MinIO, or Hetzner, with pause and resume.',
  },
  {
    src: '/screenshots/advanced_security.jpg',
    alt: 'Advanced security configuration',
    title: 'AES-256-GCM encryption',
    description: 'Encrypt data at rest before it hits the bucket. Your keys stay in your runtime.',
  },
  {
    src: '/screenshots/analytics.jpg',
    alt: 'Storage analytics',
    title: 'Live storage analytics',
    description: 'Compression ratios and stored footprint per bucket, updated live.',
  },
  {
    src: '/screenshots/bucket-policies.jpg',
    alt: 'Bucket policies',
    title: 'Bucket policies & quotas',
    description: 'Storage quotas, bucket aliases, and lifecycle rules — one screen per bucket.',
  },
  {
    src: '/screenshots/filebrowser.jpg',
    alt: 'Object browser',
    title: 'Built-in object browser',
    description: 'Browse buckets, preview files, and manage objects from the embedded web UI.',
  },
];
---

<div class="screenshot-gallery">
  {
    screenshots.map((s) => (
      <figure class="screenshot-tile">
        <div class="screenshot-frame" data-src={s.src} data-alt={s.alt}>
          <img
            src={s.src}
            alt={s.alt}
            width="1147"
            height="1440"
            loading="eager"
            decoding="async"
          />
          <div class="glassbox">
            <h3>{s.title}</h3>
            <p>{s.description}</p>
          </div>
        </div>
      </figure>
    ))
  }
</div>

<dialog id="lightbox" class="lightbox">
  <form method="dialog" class="lightbox-close-wrapper">
    <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
  </form>
  <img id="lightbox-img" src="" alt="" loading="lazy" />
</dialog>

<script>
  const frames = document.querySelectorAll('.screenshot-frame');
  const dialog = document.getElementById('lightbox') as HTMLDialogElement;
  const img = document.getElementById('lightbox-img') as HTMLImageElement;

  if (frames.length > 0 && dialog && img) {
    frames.forEach(frame => {
      frame.addEventListener('click', () => {
        const src = frame.getAttribute('data-src');
        const alt = frame.getAttribute('data-alt');
        if (src) {
          img.src = src;
          img.alt = alt || '';
          dialog.showModal();
        }
      });
    });

    // Close on backdrop click
    dialog.addEventListener('click', (e) => {
      const dialogDimensions = dialog.getBoundingClientRect();
      if (
        e.clientX < dialogDimensions.left ||
        e.clientX > dialogDimensions.right ||
        e.clientY < dialogDimensions.top ||
        e.clientY > dialogDimensions.bottom
      ) {
        dialog.close();
      }
    });
  }
</script>

<style>
  .screenshot-gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin: 2rem 0;
  }

  @media (min-width: 600px) {
    .screenshot-gallery {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1000px) {
    .screenshot-gallery {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .screenshot-tile {
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .screenshot-frame {
    position: relative;
    border: 1px solid var(--rule);
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg-soft);
    box-shadow: var(--shadow-sm);
    aspect-ratio: 4 / 3;
    cursor: pointer;
  }

  .screenshot-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .screenshot-frame:hover img {
    transform: scale(1.1);
  }

  .glassbox {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    background: rgba(15, 23, 42, 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    transform: translateY(100%);
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .screenshot-frame:hover .glassbox {
    transform: translateY(0);
    opacity: 1;
  }

  .glassbox h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.1rem;
    color: var(--brand);
    font-weight: 700;
  }

  .glassbox p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--ink-strong);
    line-height: 1.5;
  }

  /* === Lightbox Styles === */
  .lightbox {
    padding: 0;
    border: none;
    border-radius: 8px;
    background: transparent;
    max-width: 90vw;
    max-height: 90vh;
    overflow: visible;
  }

  .lightbox::backdrop {
    background: rgba(11, 15, 25, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .lightbox img {
    display: block;
    max-width: 100%;
    max-height: 90vh;
    border-radius: 8px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    object-fit: contain;
  }

  .lightbox-close-wrapper {
    position: absolute;
    top: -2rem;
    right: -2rem;
  }

  .lightbox-close {
    background: var(--bg-card);
    border: 1px solid var(--rule);
    color: var(--ink-strong);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--shadow-md);
    transition: all 0.2s ease;
  }

  .lightbox-close:hover {
    background: var(--brand);
    border-color: var(--brand);
    color: #0b0f19;
    transform: scale(1.1);
  }
  
  @media (max-width: 768px) {
    .lightbox-close-wrapper {
      top: 0.5rem;
      right: 0.5rem;
    }
    .lightbox-close {
      width: 32px;
      height: 32px;
      font-size: 1.2rem;
    }
  }
</style>
